# Local environment example for Learn AI quiz
# Copy this file to .env.local and fill in real values (do NOT commit .env.local)

# Primary provider (OpenAI-compatible)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# When developing locally you can force the route to return mock quizzes even if
# an API key is present. Set to 'true' to avoid provider calls and charges.
FORCE_MOCK=true

# Optional: Google Gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-mini

# Optional tuning
# QUIZ_TEMPERATURE=0.2
# QUIZ_MAX_TOKENS=800

# Notes:
# - Do not commit .env.local to source control. Add .env.local to .gitignore if not already present.
# - Restart the dev server after editing .env.local: `npm run dev`.
