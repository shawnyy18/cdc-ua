# ==================================================
# ECOKONEK ENVIRONMENT VARIABLES TEMPLATE
# ==================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to Git!
# ==================================================

# --------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# --------------------------------------------------
# Get these from: https://supabase.com/dashboard
# Settings > API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Supabase service role key
# ONLY use server-side! Never expose to client!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------------
# GOOGLE GEMINI AI (Optional - for Chatbot)
# --------------------------------------------------
# Get your API key from: https://makersuite.google.com/app/apikey
# NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# --------------------------------------------------
# APPLICATION CONFIGURATION (Optional)
# --------------------------------------------------
# Base URL for your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (development, production, test)
NODE_ENV=development

# --------------------------------------------------
# NOTES:
# --------------------------------------------------
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Variables without the prefix are server-side only
# - Restart your dev server after changing environment variables
# - See ENV_SETUP_GUIDE.md for detailed setup instructions
